# RestoraX — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All RESTORAX_* variables are read by restorax/config.py (pydantic-settings).
# Variables without RESTORAX_ prefix are used by honcho / Docker Compose.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no setup required for local dev)
RESTORAX_DATABASE_URL=sqlite+aiosqlite:///./restorax.db
# PostgreSQL (recommended for production):
# RESTORAX_DATABASE_URL=postgresql+asyncpg://restorax:restorax@localhost:5432/restorax

# ── Redis ─────────────────────────────────────────────────────────────────────
RESTORAX_REDIS_URL=redis://localhost:6379/0

# ── Storage ───────────────────────────────────────────────────────────────────
RESTORAX_STORAGE_BACKEND=local     # local | s3
RESTORAX_STORAGE_LOCAL_ROOT=./data

# S3 / MinIO (only needed when RESTORAX_STORAGE_BACKEND=s3)
RESTORAX_S3_ENDPOINT_URL=http://localhost:9000
RESTORAX_S3_BUCKET=restorax
RESTORAX_S3_ACCESS_KEY=minioadmin
RESTORAX_S3_SECRET_KEY=minioadmin

# ── ML / GPU ──────────────────────────────────────────────────────────────────
RESTORAX_DEVICE=cuda              # cpu | cuda | cuda:0 | cuda:1
RESTORAX_MODEL_DIR=./models       # directory where model weights are stored
RESTORAX_REGISTRY_MAX_LOADED=2    # max models kept in VRAM simultaneously per worker

# ── Celery worker routing ─────────────────────────────────────────────────────
# Celery queue(s) the worker consumes. Match RESTORAX_GPU_QUEUES in Procfile.
RESTORAX_GPU_QUEUES=gpu_default
# Multi-GPU: run one worker per GPU with a dedicated queue:
#   worker 0: RESTORAX_GPU_QUEUES=gpu_0  CUDA_VISIBLE_DEVICES=0
#   worker 1: RESTORAX_GPU_QUEUES=gpu_1  CUDA_VISIBLE_DEVICES=1

# ── API server ────────────────────────────────────────────────────────────────
PORT=8000                         # API port (Procfile production)
API_WORKERS=1                     # uvicorn worker processes

# ── Celery Flower monitor ─────────────────────────────────────────────────────
FLOWER_PORT=5555

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to call the API. Set to your server IP in production.
NEXT_PUBLIC_API_URL=http://localhost:8000
